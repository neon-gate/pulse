{
  "name": "pulse",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "pulse": "pnpm --filter ./repos/apps/pulse dev",
    "shinoda": "pnpm --filter ./repos/agents/shinoda dev",
    "chester": "pnpm --filter ./repos/agents/chester dev",
    "emily": "pnpm --filter ./repos/agents/emily dev",
    "lint": "biome check .",
    "format": "biome format --write --vcs-use-ignore-file=true .",
    "prepare": "husky",
    "postinstall": "husky",
    "infra": "pnpm docker:down && pnpm install && pnpm docker:up && pnpm docker:ps",
    "docker:down": "bash bin/docker/docker-down.sh",
    "docker:up": "bash bin/docker/docker-up.sh",
    "docker:ps": "bash bin/docker/docker-ps.sh",
    "dx:cleanup": "bash bin/dx/tooling/cleanup.sh",
    "dx:reset": "pnpm dx:cleanup && pnpm install && pnpm build",
    "dx:template": "bash bin/dx/tooling/env-template.sh"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx,cjs,mjs,json,jsonc,css}": [
      "biome lint --write --files-ignore-unknown=true",
      "biome format --write --files-ignore-unknown=true"
    ]
  },
  "devDependencies": {
    "@biomejs/biome": "2.3.15",
    "socket.io-client": "^4.8.0",
    "@commitlint/cli": "^20.4.1",
    "@commitlint/config-conventional": "^20.4.1",
    "husky": "^9.1.7",
    "lint-staged": "^16.2.7",
    "turbo": "^2.6.3"
  },
  "packageManager": "pnpm@8.15.6",
  "dependencies": {
    "ai": "^6.0.104"
  },
  "pnpm": {
    "peerDependencyRules": {
      "allowedVersions": {
        "zod": "^4"
      }
    }
  }
}
