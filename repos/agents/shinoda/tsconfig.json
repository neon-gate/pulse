{
  "compilerOptions": {
    "noEmit": true,
    "baseUrl": ".",
    "target": "ES2022",
    "module": "ES2022",
    "moduleResolution": "bundler",
    "strict": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "paths": {
      "@shinoda/*": ["./src/shinoda/*"],
      "@mastra/*": ["./src/mastra/*"],
      "@signals/*": ["./src/shinoda/signals/*"]
    }
  },
  "include": ["src"]
}
