{
  "compilerOptions": {
    "noEmit": true,
    "baseUrl": ".",
    "target": "ES2022",
    "module": "ES2022",
    "moduleResolution": "bundler",
    "strict": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "paths": {
      "@shinoda/*": ["./src/shinoda/*"],
      "@shinoda/signals/*": ["./src/shinoda/signals/*"],
      "@shinoda/tools/*": ["./src/shinoda/tools/*"],
      "@shinoda/workflows/*": ["./src/shinoda/workflows/*"],
      "@shinoda/knowledge/*": ["./src/shinoda/knowledge/*"],
      "@mastra/*": ["./src/mastra/*"]
    }
  },
  "include": ["src"]
}
