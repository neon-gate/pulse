{
  "compilerOptions": {
    "noEmit": true,
    "baseUrl": ".",
    "target": "ES2022",
    "module": "ES2022",
    "moduleResolution": "bundler",
    "strict": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "paths": {
      "@shinoda": ["./src/shinoda/shinoda.agent.ts"],
      "@signals": ["./src/shinoda/signals/index.ts"],
      "@tools": ["./src/shinoda/tools/index.ts"],
      "@workflows": ["./src/shinoda/workflows/index.ts"],
      "@context": ["./src/shinoda/knowledge/context/index.ts"],
      "@instructions": ["./src/shinoda/knowledge/instructions/index.ts"],
      "@knowledge": ["./src/shinoda/knowledge/index.ts"],
      "@infra/*": ["./src/shinoda/infra/*"]
    }
  }
}
