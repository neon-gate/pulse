    "rootDir": ".",
    "baseUrl": ".",
    "declaration": true,
    "module": "CommonJS",
    "target": "ES2022",
    "strict": true,
    "esModuleInterop": true,
    "paths": {
      "@primitives": ["./src/primitives/index.ts"],
