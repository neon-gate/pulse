{
  "compilerOptions": {
    "module": "CommonJS",
    "target": "ES2022",
    "moduleResolution": "node",
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,
    "sourceMap": true,
    "outDir": "dist",
    "baseUrl": ".",
    "paths": {
      "@application/*": ["./src/hybrid-storage/application/*"],
      "@domain/*": ["./src/hybrid-storage/domain/*"],
      "@infra/*": ["./src/hybrid-storage/infra/*"],
      "@interface/*": ["./src/hybrid-storage/interface/*"],
      "@pack/environment-orchestration": ["../../packages/environment-orchestration/dist"],
      "@pack/event-inventory": ["../../packages/event-inventory/dist"],
      "@pack/kernel": ["../../packages/kernel/dist"],
      "@pack/nats-broker-messaging": ["../../packages/nats-broker-messaging/dist"],
      "@pack/patterns": ["../../packages/patterns/dist"]
    },
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist"]
}
