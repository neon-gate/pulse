{
  "compilerOptions": {
    "module": "CommonJS",
    "target": "ES2022",
    "moduleResolution": "node",
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,
    "sourceMap": true,
    "outDir": "dist",
    "baseUrl": ".",
    "paths": {
      "@core/*": ["./src/modules/core/*"],
      "@petrified/application/*": ["./src/modules/petrified/application/*"],
      "@petrified/domain/*": ["./src/modules/petrified/domain/*"],
      "@petrified/infra/*": ["./src/modules/petrified/infra/*"],
      "@petrified/interface/*": ["./src/modules/petrified/interface/*"],
      "@fort-minor/application/*": ["./src/modules/fort-minor/application/*"],
      "@fort-minor/domain/*": ["./src/modules/fort-minor/domain/*"],
      "@fort-minor/infra/*": ["./src/modules/fort-minor/infra/*"],
      "@fort-minor/interface/*": ["./src/modules/fort-minor/interface/*"],
      "@stereo/application/*": ["./src/modules/stereo/application/*"],
      "@stereo/domain/*": ["./src/modules/stereo/domain/*"],
      "@stereo/infra/*": ["./src/modules/stereo/infra/*"],
      "@stereo/interface/*": ["./src/modules/stereo/interface/*"],
    },
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist"]
}
