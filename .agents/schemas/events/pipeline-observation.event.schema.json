{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://pulse.internal/schemas/events/pipeline-observation",
  "title": "Pipeline Observation Event",
  "description": "Schema for the Backstage pipeline observation event. Backstage subscribes to all track lifecycle NATS subjects, records each event as a pipeline step, and broadcasts it to connected clients via SSE (or Socket.IO when SSE is disabled). This is the event that bridges the NATS event bus to the real-time frontend.",
  "version": "1.0.0",
  "owner": "realtime",
  "domain": "realtime",
  "createdOn": "2026-03-19",
  "updatedOn": "2026-03-19",
  "type": "object",
  "properties": {
    "observation": {
      "type": "object",
      "description": "The pipeline observation broadcast to frontend clients.",
      "properties": {
        "contract": {
          "type": "object",
          "description": "The PipelineEventPayload as defined in Backstage's event-stream.port.ts.",
          "properties": {
            "id": {
              "type": "string",
              "description": "Unique event ID for SSE Last-Event-ID replay. Must be stable and deterministic."
            },
            "type": {
              "type": "string",
              "const": "pipeline.event",
              "description": "SSE event type discriminator."
            },
            "event": {
              "type": "string",
              "description": "Original NATS subject name (e.g., 'track.uploaded')."
            },
            "trackId": {
              "type": "string",
              "description": "Track ID this pipeline event belongs to. Used for per-track SSE stream scoping."
            },
            "timestamp": {
              "type": "string",
              "format": "date-time",
              "description": "ISO 8601 timestamp when the event was recorded by Backstage."
            },
            "payload": {
              "type": "object",
              "additionalProperties": true,
              "description": "Original domain event payload."
            }
          },
          "required": ["id", "type", "event", "trackId", "timestamp", "payload"]
        },
        "transport": {
          "type": "object",
          "description": "How the observation reaches the frontend.",
          "properties": {
            "sse": {
              "type": "object",
              "properties": {
                "endpoint": { "const": "GET /pipelines/:trackId/events" },
                "featureFlag": { "const": "USE_SSE=true" },
                "replay": { "const": "Last-Event-ID header" },
                "heartbeat": { "const": ":ping comment every 15s" }
              }
            },
            "websocket": {
              "type": "object",
              "properties": {
                "gateway": { "const": "Socket.IO on same port" },
                "featureFlag": { "const": "USE_SSE=false (default)" }
              }
            }
          }
        },
        "subscribedSubjects": {
          "type": "array",
          "description": "NATS subjects that Backstage observes to build pipeline views.",
          "items": { "type": "string" },
          "examples": [
            [
              "track.upload.received",
              "track.upload.validated",
              "track.upload.stored",
              "track.uploaded",
              "track.upload.failed",
              "track.petrified.generated",
              "track.petrified.song.found",
              "track.petrified.song.unknown",
              "track.petrified.detected",
              "track.petrified.failed",
              "track.duplicate.detected",
              "track.fort-minor.started",
              "track.fort-minor.completed",
              "track.fort-minor.failed",
              "track.stereo.started",
              "track.approved",
              "track.rejected",
              "track.stereo.failed",
              "track.transcoding.started",
              "track.transcoding.completed",
              "track.transcoding.failed",
              "track.hls.generated",
              "track.hls.stored",
              "track.hls.failed"
            ]
          ]
        }
      }
    }
  },
  "required": ["observation"]
}
