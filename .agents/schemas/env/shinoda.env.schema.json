{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://pulse.internal/schemas/env/shinoda",
  "title": "Shinoda Agent Environment Variables",
  "description": "Environment variable contract for the Shinoda Mastra agent. Derived from repos/agents/shinoda/.env.template.",
  "version": "1.0.0",
  "owner": "agent",
  "domain": "agent",
  "createdOn": "2026-03-19",
  "updatedOn": "2026-03-19",
  "type": "object",
  "properties": {
    "OPENAI_API_KEY": {
      "type": "string",
      "description": "OpenAI API key for LLM inference. Required for agent operation."
    },
    "SHINODA_MODEL": {
      "type": "string",
      "default": "Composer 1.5",
      "description": "LLM model identifier used by the Shinoda agent."
    },
    "BACKSTAGE_URL": {
      "type": "string",
      "format": "uri",
      "default": "http://backstage:4001",
      "description": "Backstage service URL. Primary data source for pipeline queries."
    },
    "AUTHORITY_URL": {
      "type": "string",
      "format": "uri",
      "default": "http://authority:7000",
      "description": "Authority service health check URL."
    },
    "SLIM_SHADY_URL": {
      "type": "string",
      "format": "uri",
      "default": "http://slim-shady:7400",
      "description": "Slim Shady service health check URL."
    },
    "SOUNDGARDEN_URL": {
      "type": "string",
      "format": "uri",
      "default": "http://soundgarden:7100",
      "description": "Soundgarden service health check URL."
    },
    "PETRIFIED_URL": {
      "type": "string",
      "format": "uri",
      "default": "http://petrified:7201",
      "description": "Petrified service health check URL."
    },
    "FORT_MINOR_URL": {
      "type": "string",
      "format": "uri",
      "default": "http://fort-minor:7202",
      "description": "Fort Minor service health check URL."
    },
    "STEREO_URL": {
      "type": "string",
      "format": "uri",
      "default": "http://stereo:7203",
      "description": "Stereo service health check URL."
    },
    "MOCKINGBIRD_URL": {
      "type": "string",
      "format": "uri",
      "default": "http://mockingbird:7200",
      "description": "Mockingbird service health check URL."
    },
    "HYBRID_STORAGE_URL": {
      "type": "string",
      "format": "uri",
      "default": "http://hybrid-storage:7300",
      "description": "Hybrid Storage service health check URL."
    },
    "MONITOR_POLL_INTERVAL_MS": {
      "type": "integer",
      "default": 30000,
      "description": "Polling interval in milliseconds for Shinoda's health monitoring loop."
    },
    "STUCK_THRESHOLD_MS": {
      "type": "integer",
      "default": 60000,
      "description": "Duration in milliseconds after which a pipeline is considered stuck."
    },
    "MCP_SERVER_URL": {
      "type": "string",
      "format": "uri",
      "description": "Optional MCP observability server URL for tool-call tracing."
    }
  },
  "required": ["OPENAI_API_KEY", "BACKSTAGE_URL"],
  "examples": [
    {
      "OPENAI_API_KEY": "sk-...",
      "SHINODA_MODEL": "Composer 1.5",
      "BACKSTAGE_URL": "http://backstage:4001",
      "AUTHORITY_URL": "http://authority:7000",
      "SLIM_SHADY_URL": "http://slim-shady:7400",
      "SOUNDGARDEN_URL": "http://soundgarden:7100",
      "PETRIFIED_URL": "http://petrified:7201",
      "FORT_MINOR_URL": "http://fort-minor:7202",
      "STEREO_URL": "http://stereo:7203",
      "MOCKINGBIRD_URL": "http://mockingbird:7200",
      "HYBRID_STORAGE_URL": "http://hybrid-storage:7300",
      "MONITOR_POLL_INTERVAL_MS": 30000,
      "STUCK_THRESHOLD_MS": 60000
    }
  ]
}
