{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://pulse.internal/schemas/template",
  "title": "Schema Template",
  "description": "Meta-template that defines the canonical structure for all Pulse JSON schema documents. Every schema in the .agents/schemas/ directory must follow this pattern.",
  "version": "1.0.0",
  "owner": "platform",
  "domain": "meta",
  "createdOn": "2026-03-19",
  "updatedOn": "2026-03-19",
  "type": "object",
  "properties": {
    "$schema": {
      "type": "string",
      "const": "http://json-schema.org/draft-07/schema#",
      "description": "JSON Schema draft version. Always draft-07."
    },
    "$id": {
      "type": "string",
      "pattern": "^https://pulse\\.internal/schemas/",
      "description": "Unique schema identifier using the pulse.internal namespace."
    },
    "title": {
      "type": "string",
      "description": "Human-readable schema title."
    },
    "description": {
      "type": "string",
      "description": "What this schema defines and where it is used."
    },
    "version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$",
      "description": "Semantic version of the schema."
    },
    "owner": {
      "type": "string",
      "description": "Team or domain that owns this schema (e.g., 'streaming', 'identity', 'platform')."
    },
    "domain": {
      "type": "string",
      "enum": [
        "streaming",
        "identity",
        "ai",
        "realtime",
        "platform",
        "agent",
        "meta"
      ],
      "description": "Bounded context this schema belongs to."
    },
    "createdOn": {
      "type": "string",
      "format": "date",
      "description": "ISO date when the schema was first created."
    },
    "updatedOn": {
      "type": "string",
      "format": "date",
      "description": "ISO date of last modification."
    },
    "type": {
      "type": "string",
      "description": "Root JSON Schema type."
    },
    "properties": {
      "type": "object",
      "description": "Schema properties defining the contract."
    },
    "required": {
      "type": "array",
      "items": { "type": "string" },
      "description": "List of required property names."
    },
    "examples": {
      "type": "array",
      "description": "One or more valid example instances of this schema."
    }
  },
  "required": [
    "$schema",
    "$id",
    "title",
    "description",
    "version",
    "owner",
    "domain",
    "type",
    "properties"
  ],
  "examples": [
    {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "$id": "https://pulse.internal/schemas/health/liveness",
      "title": "Liveness Check Response",
      "description": "Response schema for GET /health liveness probes.",
      "version": "1.0.0",
      "owner": "platform",
      "domain": "platform",
      "createdOn": "2026-03-19",
      "updatedOn": "2026-03-19",
      "type": "object",
      "properties": {
        "status": {
          "type": "string",
          "const": "ok"
        }
      },
      "required": ["status"],
      "examples": [{ "status": "ok" }]
    }
  ]
}
